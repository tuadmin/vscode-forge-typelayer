{
  "name": "forge-typelayer",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "1.0.1-alpha.10",
  "publisher": "tuadmin",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tuadmin/vscode-forge-typelayer"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "main": "./src/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "forgeTypeLayer.toggleMode",
        "title": "%cmd.toggleMode%"
      },
      {
        "command": "forgeTypeLayer.selectMode",
        "title": "%cmd.selectMode%"
      },
      {
        "command": "forgeTypeLayer.emitCurrentFile",
        "title": "%cmd.emitCurrentFile%"
      },
      {
        "command": "forgeTypeLayer.reconstructFromPublicArtifacts",
        "title": "%cmd.reconstruct%"
      },
      {
        "command": "forgeTypeLayer.showSpec",
        "title": "%cmd.showSpec%"
      },
      {
        "command": "forgeTypeLayer.showRuntimeInfo",
        "title": "%cmd.showRuntimeInfo%"
      },
      {
        "command": "forgeTypeLayer.doctorWorkspace",
        "title": "%cmd.doctorWorkspace%"
      }
    ],
    "configuration": {
      "title": "%cfg.title%",
      "properties": {
        "forgeTypeLayer.defaultMode": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "manual",
            "auto"
          ],
          "description": "%cfg.defaultMode%"
        },
        "forgeTypeLayer.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "%cfg.showNotifications%"
        },
        "forgeTypeLayer.useWorkspaceTypescript": {
          "type": "boolean",
          "default": true,
          "description": "%cfg.useWorkspaceTypescript%"
        },
        "forgeTypeLayer.preferredRuntime": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "typescript-api",
            "tsc",
            "bun",
            "deno"
          ],
          "description": "%cfg.preferredRuntime%"
        },
        "forgeTypeLayer.preLint": {
          "type": "boolean",
          "default": true,
          "description": "%cfg.preLint%"
        },
        "forgeTypeLayer.removeComments": {
          "type": "boolean",
          "default": false,
          "description": "%cfg.removeComments%"
        },
        "forgeTypeLayer.target": {
          "type": "string",
          "default": "ES2022",
          "enum": [
            "ES2018",
            "ES2020",
            "ES2022",
            "ESNext"
          ],
          "description": "%cfg.target%"
        },
        "forgeTypeLayer.entriesFile": {
          "type": "string",
          "default": "forge-typelayer.entries.json",
          "description": "%cfg.entriesFile%"
        },
        "forgeTypeLayer.lockSuffixes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^\\.\\w[\\w.]*\\.m?ts$",
            "patternErrorMessage": "Each suffix must start with '.' and end with '.ts' or '.mts' (e.g. '.source.ts', '.forge.mts'). JS output extensions (.js, .jsx, etc.) are not valid here — Forge handles the output mapping automatically."
          },
          "default": [
            ".f.ts",
            ".forge.ts",
            ".source.ts",
            ".f.mts",
            ".forge.mts",
            ".source.mts"
          ],
          "markdownDescription": "List of **source file suffixes** that trigger internal locking and artifact renaming. Each suffix must end with `.ts` or `.mts` — Forge automatically maps them to `.js`/`.mjs` + `.d.ts`/`.d.mts` on output.\n\nExamples: `.source.ts`, `.forge.ts`, `.f.ts`, `.source.mts`\n\n> ⚠️ Custom entries **must end in `.ts` or `.mts`**. Adding `.js` or other output extensions is a misconfiguration and will be rejected."
        },
        "forgeTypeLayer.addWatermark": {
          "type": "boolean",
          "default": true,
          "description": "Add an autogenerated warning header to the emitted .js and .d.ts files."
        },
        "forgeTypeLayer.reconstructSuffix": {
          "type": "string",
          "default": ".reconstructed.mts",
          "description": "%cfg.reconstructSuffix%"
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": "l10n/*.json",
        "url": "./schemas/l10n.schema.json"
      },
      {
        "fileMatch": "package.nls*.json",
        "url": "./schemas/package.nls.schema.json"
      }
    ]
  },
  "scripts": {
    "dev:host": "node ./test/devHost.js",
    "compile": "node -e \"console.log('No build step required.')\"",
    "test:audit": "bun test test/unit/integrity/",
    "test:unit": "bun test --cwd . test/unit/*.test.js",
    "test:e2e": "node ./test/runTest.js",
    "test": "npm run test:audit && npm run test:unit && npm run test:e2e",
    "package": "vsce package",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "dependencies": {
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.95.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.1",
    "mocha": "^7.2.0",
    "ovsx": "^0.10.3"
  }
}